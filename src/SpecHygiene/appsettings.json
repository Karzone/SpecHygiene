{
  "Analysis": {
    "SolutionPaths": [],
    "FeatureFilePattern": "*.feature",
    "ExcludeFolders": [ "bin", "obj", "node_modules", ".git" ],
    "StepKeywords": [ "Given", "When", "Then", "And", "But" ],
    "ShowDataErrors": true,
    "DuplicateMode": "Scenario"
  },
  "CoverageAnalysis": {
    "Enabled": true,
    "UseSyntacticDiscovery": true,
    "UseStepAssemblyReferences": true,
    "IncludeIgnoredScenarios": true,
    "StepDefinitionFilePatterns": [ "*Steps.cs", "*StepDefinitions.cs", "*Bindings.cs" ]
  },
  "UnusedCodeAnalysis": {
    "Enabled": true,
    "IncludePublicMembers": false
  },
  "Output": {
    "OutputDirectory": "./reports",
    "GenerateHtml": true
  }
}
